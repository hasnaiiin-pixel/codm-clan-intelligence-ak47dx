# CODM AK47DX - esempio ambiente locale
# Copia questo file in .env.local e compila i valori reali.

# Supabase frontend
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# URL pubblico app Vercel, usato per redirect email, inviti, calendar
NEXT_PUBLIC_APP_URL=https://YOUR_PROJECT.vercel.app
NEXT_PUBLIC_APP_NAME=CODM Clan Intelligence

# OCR backend pubblico opzionale: NON usare localhost su Vercel
# Esempio: https://ak47dx-ocr-api.onrender.com
NEXT_PUBLIC_OCR_BACKEND_URL=

# Server-only: impostare SOLO su Vercel, non pubblicare su GitHub
SUPABASE_SERVICE_ROLE_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CRON_SECRET=
